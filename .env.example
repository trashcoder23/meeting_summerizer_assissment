# Google AI API Key — used for Gemini 2.5 Flash summarization
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_ai_key_here

# Google Cloud API Key — used for Google Speech-to-Text transcription
# Get yours at: https://console.cloud.google.com/apis/credentials
# Make sure "Cloud Speech-to-Text API" is enabled on your project
GOOGLE_SPEECH_API_KEY=your_google_cloud_speech_key_here
